# ── Calendly Backend ─────────────────────────────────────────────
# Shared secret between the React CRM and the webhook backend.
# Must match the FRONTEND_SECRET value in backend/.env
# Generate a strong random value: openssl rand -hex 32
VITE_FRONTEND_SECRET=
