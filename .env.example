# Simply Breathe CRM — Frontend Environment Variables
# Copy this file to .env and fill in your values.

# ── Calendly Backend URL ─────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles routing to localhost:3001).
# In production, set to your backend's public URL e.g. https://api.yourdomain.com
VITE_CALENDLY_BACKEND=

# ── Frontend Secret ───────────────────────────────────────────────
# DO NOT set VITE_FRONTEND_SECRET here. Vite bakes VITE_* vars into the
# public JS bundle, which would expose the secret to anyone who visits the app.
#
# In local dev: the Vite proxy injects x-frontend-secret server-side automatically.
# In production: configure your reverse proxy (Nginx, Caddy, etc.) to inject the
#   header at the proxy layer — FRONTEND_SECRET never touches the browser.
#
# VITE_FRONTEND_SECRET=  ← intentionally disabled
