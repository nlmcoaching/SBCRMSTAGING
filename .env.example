# Simply Breathe CRM — Frontend Environment Variables
# Copy this file to .env and fill in your values.

# ── Calendly Backend URL ─────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles routing to localhost:3001).
# In production, set to your backend's public URL e.g. https://api.yourdomain.com
VITE_CALENDLY_BACKEND=

# ── Frontend Secret (production only) ────────────────────────────
# Must match FRONTEND_SECRET in backend/.env.
# In local dev the Vite proxy injects this header server-side (no need to set here).
# In a production reverse-proxy setup (Nginx etc.) inject the header at the proxy
# layer instead of setting this var — that keeps the secret out of the JS bundle.
# Only set this as a last resort if a proxy is not available.
VITE_FRONTEND_SECRET=
