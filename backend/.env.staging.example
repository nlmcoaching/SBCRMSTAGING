# Simply Breathe Backend — STAGING environment
# Copy to backend/.env on the staging server (/var/www/sbcrm-staging)
# Generate ALL secrets fresh — do not copy from production.

NODE_ENV=production
PORT=3002

# ── Calendly (separate staging webhook subscription) ─────────────
# Webhook URL: https://sbcrm-staging.simplybreathe.ai/api/webhooks/calendly
CALENDLY_WEBHOOK_SIGNING_KEY=

# ── Queue encryption ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
QUEUE_ENCRYPTION_KEY=

# ── Frontend secret (must match Nginx proxy_set_header) ──────────
# Generate: openssl rand -hex 32
FRONTEND_SECRET=

# ── Admin secret (debug endpoints) ───────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# ── Calendly API (event descriptions) ────────────────────────────
CALENDLY_API_TOKEN=

# ── Resend (real emails — test carefully) ────────────────────────
RESEND_API_KEY=
RESEND_FROM=jeff@simplybreathe.ai
RESEND_REPLY_TO=

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://sbcrm-staging.simplybreathe.ai
