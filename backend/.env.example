# Simply Breathe Backend — Environment Variables
# Copy this file to .env and fill in your values.
#
# Secret hygiene: never commit .env. Do not zip/sync/share a folder that contains live keys.
# Workstation .env is plaintext — prefer test keys locally; on shared/prod hosts use a vault
# (HashiCorp Vault / AWS Secrets Manager). Rotate any key that may have left this machine.

# ── Server ──────────────────────────────────────────────────────
PORT=3001
# Set to 1 when behind ngrok, nginx, or Caddy (rate-limit client IP). Do NOT set if port 3001 is directly public.
TRUST_PROXY=

# ── Calendly Webhook Signing Key ────────────────────────────────
# Found in: Calendly Dashboard → Integrations → Webhooks → your subscription → Signing Key
# Or generate your own (openssl rand -hex 32) and pass it as `signing_key` when creating the
# webhook subscription via POST /webhook_subscriptions — Calendly no longer returns the key
# in the create response for PAT-created subscriptions.
# Required in production (server exits without it). In dev, unsigned webhooks are REJECTED
# unless you explicitly set ALLOW_UNSIGNED_CALENDLY_WEBHOOKS=true (do not use with public ngrok).
CALENDLY_WEBHOOK_SIGNING_KEY=
# ALLOW_UNSIGNED_CALENDLY_WEBHOOKS=true

# ── Queue Encryption Key ────────────────────────────────────────
# 32-byte hex key to encrypt pending-events.json at rest (AES-256-GCM).
# Generate: openssl rand -hex 32
# Must be exactly 64 hex characters (/^[0-9a-f]{64}$/i). Malformed values are rejected
# at startup in production (they must not silently disable encryption).
# If left blank, queue is stored as plaintext (dev/testing only).
QUEUE_ENCRYPTION_KEY=

# ── Frontend Secret ─────────────────────────────────────────────
# Shared secret between the React CRM and the backend for /pending and /acknowledge.
# Required in production AND in normal local use. Pass as header:  x-frontend-secret: <your-secret>
# Generate a strong random value: openssl rand -hex 32
# Injected by the Vite proxy (dev) or reverse proxy (production) — never put in VITE_* env vars.
FRONTEND_SECRET=

# Local-only escape hatch: allow CRM APIs without FRONTEND_SECRET.
# NEVER enable with a public ngrok tunnel. start.ps1 refuses ngrok when this is true.
# ALLOW_INSECURE_DEV_AUTH=true

# ── Admin Secret ────────────────────────────────────────────────
# Secret token required for the debug admin endpoints (GET/DELETE /api/calendly/events).
# Pass as header:  x-admin-token: <your-secret>
# Generate a strong random value: openssl rand -hex 32
ADMIN_SECRET=

# ── Stripe Webhooks ─────────────────────────────────────────────
# Signing secret from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Register endpoint URL: https://YOUR-DOMAIN/api/webhooks/stripe
# Listen for: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed, charge.refunded, charge.refund.updated
STRIPE_WEBHOOK_SECRET=

# Local-only: accept Stripe webhooks without a signing secret (mirrors Calendly flag).
# NEVER enable with a public ngrok tunnel. start.ps1 refuses ngrok when this is true.
# ALLOW_UNSIGNED_STRIPE_WEBHOOKS=true

# ── Stripe API Key (refunds) ────────────────────────────────────
# Used by POST /api/stripe/refund only. Prefer a restricted key with Refunds write
# (rk_test_… / rk_live_…) — not a full sk_live_ secret key.
# Local/dev: use sk_test_ or rk_test_. Live keys with NODE_ENV≠production print a startup warning
# unless ALLOW_LIVE_STRIPE_IN_DEV=true (intentional live testing only).
# If left blank, the CRM's Refund buttons will report that refunds are not configured.
STRIPE_SECRET_KEY=
# ALLOW_LIVE_STRIPE_IN_DEV=true

# Personal Access Token from: Calendly → Integrations → API & Webhooks → Personal Access Tokens
# Used to fetch event type descriptions for session cards (requires scheduled_events:read scope).
# If left blank, session descriptions will not be populated.
CALENDLY_API_TOKEN=

# ── Resend Email ─────────────────────────────────────────────────
# API key from: https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address (must be on a domain you have verified in Resend)
RESEND_FROM=you@yourdomain.com

# Reply-to address (defaults to RESEND_FROM if not set)
RESEND_REPLY_TO=

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React CRM.
# For local dev: http://localhost:5173
# For production: https://yourdomain.com (set this before going live!)
ALLOWED_ORIGINS=http://localhost:5173
