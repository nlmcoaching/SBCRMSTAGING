# Nginx site config for sbcrm-staging.simplybreathe.ai
# Copy to /etc/nginx/sites-available/sbcrm-staging
#
# Before enabling:
#   1. Replace FRONTEND_SECRET_PLACEHOLDER with the value from backend/.env
#   2. Adjust root path if your deploy directory differs
#   3. Run: sudo nginx -t && sudo systemctl reload nginx
#   4. Run: sudo certbot --nginx -d sbcrm-staging.simplybreathe.ai

server {
    listen 80;
    server_name sbcrm-staging.simplybreathe.ai;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name sbcrm-staging.simplybreathe.ai;

    # Certbot will populate these after first run:
    # ssl_certificate     /etc/letsencrypt/live/sbcrm-staging.simplybreathe.ai/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/sbcrm-staging.simplybreathe.ai/privkey.pem;

    root /var/www/sbcrm-staging/dist;
    index index.html;

    # SPA — serve index.html for client-side routes
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Backend API — staging runs on port 3002
    location /api/ {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Inject shared secret server-side (never expose in JS bundle)
        proxy_set_header x-frontend-secret FRONTEND_SECRET_PLACEHOLDER;
    }

    # Backend health check (optional direct access)
    location /health {
        proxy_pass http://127.0.0.1:3002;
        proxy_set_header Host $host;
    }

    # Static assets — long cache for hashed Vite files
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
